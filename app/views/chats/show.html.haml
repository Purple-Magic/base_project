= tramway_container do
  .space-y-8.py-10
    = tramway_title text: @chat.title

    %p.text-sm.text-slate-600
      = pluralize(@chat.members_count, 'member')
      in this chat

    .grid.gap-8{ class: 'lg:grid-cols-[minmax(0,2fr)_minmax(18rem,1fr)]' }
      .space-y-4
        .rounded-3xl.border.border-slate-200.bg-white.p-5.shadow-sm
          %p.text-xs.font-semibold.uppercase.tracking-widest.text-slate-500 Chat UUID
          %p.mt-2.break-all.font-mono.text-sm.text-slate-800= @chat.uuid
          %p.mt-4.text-sm.text-slate-600
            Created
            = l(@chat.created_at, format: :long)

        = tramway_chat chat_id: dom_id(@chat.object),
          messages: @chat.transcript_messages,
          message_form: nil,
          send_message_path: '#',
          send_messages_enabled: false

      .space-y-4
        %h2.text-lg.font-semibold.text-slate-900 Members

        = tramway_table do
          = tramway_header headers: ['Member', 'Chats']

          - @members.each do |member|
            = tramway_row do
              = tramway_cell do
                %span.font-medium.text-slate-900= member.full_name
              = tramway_cell do
                = member.chats_count
